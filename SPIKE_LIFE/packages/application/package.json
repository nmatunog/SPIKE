{
  "name": "@spike-life/application",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build -w @spike-life/domain && npm run build -w @spike-life/infrastructure && tsc -p tsconfig.json && vitest run --config vitest.dist.config.ts"
  },
  "dependencies": {
    "@spike-life/domain": "*",
    "@spike-life/ui": "*"
  },
  "devDependencies": {
    "@spike-life/infrastructure": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
