{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "command": ".cursor/hooks/push-on-session-end.sh",
        "timeout": 300
      }
    ],
    "afterShellExecution": [
      {
        "command": ".cursor/hooks/ship-after-build-hook.sh",
        "matcher": "npm run (build|ship)|vite build",
        "timeout": 300
      }
    ]
  }
}
