# Local dev: leave empty — Vite proxies /api → http://localhost:4000 (vite.config.js).
#
# Netlify / production build: set in Site settings → Environment variables (same name).
# Must be set before "Deploy" so Vite can inline it. Example:
#   VITE_API_URL=https://your-api.onrender.com
# No trailing slash. Requests go to VITE_API_URL + /api/...
VITE_API_URL=

# Set true to run as static-only demo (no API required).
# Useful for simple Netlify deployment when backend is not ready.
VITE_STATIC_ONLY=false

# Supabase frontend keys (for Option B migration).
# Keep empty until you wire Supabase in the frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
