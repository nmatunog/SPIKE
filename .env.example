# Supabase (production + local dev with real auth)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Preview mode: orientation + master blueprint only (no sign-in).
# Leave false for normal development and production.
VITE_STATIC_ONLY=false

# Demo sign-in for allowlisted @example.com accounts (password123). Enabled by default.
# Set false to disable mock accounts on a deployed build.
# VITE_MOCK_AUTH=false

# Local JWT dev only — leave empty when using Supabase.
# Vite proxies /api → http://localhost:4000 when unset.
VITE_API_URL=

# Optional: direct wrangler deploy (scripts/deploy-production.sh)
# CLOUDFLARE_ACCOUNT_ID=66e72ecb625c7e76d017a366156ec53f

# Capacitor live reload (optional — uncomment in capacitor.config.json server block)
# Point server.url at your LAN IP, e.g. http://192.168.1.10:5173
