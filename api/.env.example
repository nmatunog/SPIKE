DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-long-random-secret"
PORT=4000

# Venture Coach AI — server-side only (never expose in VITE_* vars).
# Copy this file to api/.env and set keys there (api/.env is gitignored).
# Gemini is tried first; OpenAI is used when Gemini hits quota/rate limits.
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# VENTURE_STUDIO_OPENAI_API_KEY=  # Research canvas only; falls back to OPENAI_API_KEY

# Optional: if set, POST /api/auth/setup (first admin only) must send the same value as setupSecret.
# Use a long random string in production so only you can create the first account.
# SETUP_SECRET=
