{
  "name": "spike",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-facilitators-content-reference.mjs && npm run build:spike-life && vite build && node scripts/copy-protected-coach-decks.mjs && node scripts/strip-public-coach-decks.mjs && bash scripts/strip-oversized-pages-assets.sh && node scripts/verify-dist-assets.mjs",
    "build:ra-spike": "bash scripts/build-ra-spike.sh",
    "build:spike-life": "npm run build:packages --prefix SPIKE_LIFE",
    "build:facilitators-reference": "node scripts/build-facilitators-content-reference.mjs",
    "postbuild": "bash scripts/postbuild-ship.sh",
    "ship": "npm run lint && npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:cf": "bash ./scripts/deploy-cloudflare.sh",
    "deploy:prod": "bash ./scripts/deploy-production.sh",
    "push:dev": "bash ./scripts/auto-push-dev-revisions.sh",
    "ship:dirty": "bash scripts/ship-if-dirty.sh",
    "db:migrate": "bash scripts/run-supabase-migrations.sh",
    "smoke:content": "node scripts/smoke-content-files.mjs",
    "smoke:content:loader": "node scripts/smoke-content-loader.mjs",
    "simulate:day1": "node scripts/simulate-day1.mjs",
    "simulate:week1": "node scripts/simulate-week1.mjs",
    "smoke:week1-content": "node scripts/smoke-week1-content.mjs",
    "smoke:canvas-pptx": "node scripts/smoke-canvas-pptx.mjs",
    "smoke:fec-canvas-schema": "node scripts/smoke-fec-canvas-schema.mjs",
    "smoke:coach-compose": "node scripts/smoke-coach-compose.mjs",
    "smoke:mentor-week1": "node scripts/smoke-mentor-week1.mjs",
    "smoke:faculty-week1": "node scripts/smoke-faculty-week1.mjs",
    "create-superuser": "node scripts/create-superuser.mjs",
    "import:faculty-pptx": "node scripts/import-faculty-pptx.mjs",
    "smoke:week1-journey": "node scripts/smoke-week1-journey.mjs",
    "smoke:week2-discovery": "node scripts/smoke-week2-discovery.mjs",
    "smoke:squad-xp": "node scripts/smoke-squad-xp.mjs",
    "smoke:participant-hydration": "node scripts/smoke-participant-hydration.mjs",
    "smoke:intern-logout-backup": "node scripts/smoke-intern-logout-backup.mjs",
    "smoke:venture-studio": "node scripts/smoke-venture-studio.mjs",
    "smoke:dream-board-merge": "node scripts/smoke-dream-board-merge.mjs",
    "smoke:spike-life-workshop": "node scripts/smoke-spike-life-workshop.mjs",
    "smoke:stage-gate-ceremony": "node scripts/smoke-stage-gate-ceremony.mjs",
    "smoke:ra-spike-week1": "node scripts/smoke-ra-spike-week1.mjs",
    "smoke:ra-spike-week2": "node scripts/smoke-ra-spike-week2.mjs",
    "smoke:ra-spike-gates": "node scripts/smoke-ra-spike-gates.mjs",
    "audit:intern-recovery": "node scripts/audit-intern-cloud-recovery.mjs",
    "cap:sync": "CAPACITOR=true npm run build && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:run:ios": "npm run cap:sync && npx cap run ios",
    "cap:run:android": "npm run cap:sync && npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.104.0",
    "@spike-life/application": "file:SPIKE_LIFE/packages/application",
    "@spike-life/board-config": "file:SPIKE_LIFE/packages/board-config",
    "@spike-life/content-core": "file:SPIKE_LIFE/packages/content-core",
    "@spike-life/content-philippines": "file:SPIKE_LIFE/packages/content-philippines",
    "@spike-life/domain": "file:SPIKE_LIFE/packages/domain",
    "@spike-life/infrastructure": "file:SPIKE_LIFE/packages/infrastructure",
    "@spike-life/ui": "file:SPIKE_LIFE/packages/ui",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.17.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.9"
  }
}
