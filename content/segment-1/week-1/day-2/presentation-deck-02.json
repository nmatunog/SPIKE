      "presentationId": "presentation-day-2-deck-02",
      "sortOrder": 2,
      "title": "Interview & Observation Protocol",
      "body": "Prepare 5 questions before you speak to a practitioner.\nListen for: client problems, career path, daily habits, industry changes.\nCapture quotes — your business plan will use this evidence.",
      "speakerNotes": "Distribute interview worksheet. 5 min.",
      "discussionQuestions": [
        "What is one question you are afraid to ask?"
      ],
      "imageUrl": "/content/segment-1/week-1/day-2/deck-02/slide-02.png"
